// Boj clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace boj {

    entity Indicator {
        id: string @unique
        code: string
        name: string
        unit: string
        source: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Observation {
        id: string @unique
        indicatorId: string
        country: string
        period: string
        value: float
        createdAt: datetime
        updatedAt: datetime
    }

    entity Country {
        id: string @unique
        iso3: string
        name: string
        region: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Series {
        id: string @unique
        indicatorId: string
        frequency: string
        startPeriod: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Report {
        id: string @unique
        title: string
        publishedAt: datetime
        contentRef: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity ExchangeRate {
        id: string @unique
        base: string
        quote: string
        rate: float
        asOf: datetime
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
